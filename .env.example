# Application
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/incubatex

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI (for AI poster generation — get key at platform.openai.com)
OPENAI_API_KEY=sk-...

# Google Service Account (for auto-creating Google Forms on cohort creation)
# Setup: console.cloud.google.com → IAM → Service Accounts → Create key (JSON)
# Enable APIs: Google Forms API + Google Drive API
GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
